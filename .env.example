# =============================================================================
# AI Career Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# All settings use the pattern: {section}_{field}
# =============================================================================

# ---------------------------------------------------------------------------
# APPLICATION
# ---------------------------------------------------------------------------
APP_PROJECT_NAME=AI Career Agent
APP_VERSION=0.1.0
APP_ENVIRONMENT=development
APP_DEBUG=false
APP_SECRET_KEY=
APP_FRONTEND_URL=http://localhost:5173
APP_API_HOST=0.0.0.0
APP_API_PORT=8000
APP_API_ROOT_PATH=/api
APP_CORS_ORIGINS=http://localhost:5173

# ---------------------------------------------------------------------------
# DATABASE
# ---------------------------------------------------------------------------
# SQLite (default, zero-config):
DATABASE_URL=sqlite:///./data/ai_career_agent.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/ai_career_agent
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false
DATABASE_POOL_PRE_PING=true
DATABASE_POOL_RECYCLE=3600
DATABASE_MIGRATE_ON_START=false

# ---------------------------------------------------------------------------
# LLM / AI (Gemini, Groq, Ollama)
# ---------------------------------------------------------------------------
GEMINI_PROVIDER=gemini
# At least one API key required:
GEMINI_GEMINI_API_KEY=
GEMINI_GEMINI_MODEL=gemini-2.0-flash
GEMINI_GEMINI_MAX_TOKENS=8192
GEMINI_GEMINI_TEMPERATURE=0.7

GEMINI_GROQ_API_KEY=
GEMINI_GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_GROQ_MAX_TOKENS=8192
GEMINI_GROQ_TEMPERATURE=0.7

GEMINI_OLLAMA_BASE_URL=http://localhost:11434
GEMINI_OLLAMA_MODEL=llama3.1:8b
GEMINI_OLLAMA_MAX_TOKENS=4096
GEMINI_OLLAMA_TEMPERATURE=0.7

GEMINI_CACHE_TTL_SECONDS=3600

# ---------------------------------------------------------------------------
# PLAYWRIGHT (Browser Automation)
# ---------------------------------------------------------------------------
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_BROWSER_TYPE=chromium
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_SLOW_MO_MS=50
PLAYWRIGHT_VIEWPORT_WIDTH=1920
PLAYWRIGHT_VIEWPORT_HEIGHT=1080
PLAYWRIGHT_USER_DATA_DIR=
PLAYWRIGHT_MAX_PAGES=4
PLAYWRIGHT_RATE_LIMIT_MS=2000
PLAYWRIGHT_RETRY_COUNT=3
PLAYWRIGHT_RETRY_BACKOFF_FACTOR=2.0
PLAYWRIGHT_STEALTH_MODE=true
PLAYWRIGHT_USER_AGENT=

# ---------------------------------------------------------------------------
# LOGGING
# ---------------------------------------------------------------------------
LOGGING_LEVEL=INFO
LOGGING_FORMAT=json
LOGGING_OUTPUT=both
LOGGING_FILE_PATH=storage/logs/runtime.log
LOGGING_JSON_ENSURE_ASCII=false
LOGGING_INCLUDE_TRACEBACK=true
LOGGING_AGENT_ACTIVITY_PATH=storage/logs/agent_activity.json

# ---------------------------------------------------------------------------
# EMAIL (Application Status Monitoring — optional)
# ---------------------------------------------------------------------------
EMAIL_ENABLED=false
EMAIL_PROVIDER=imap
EMAIL_HOST=
EMAIL_PORT=993
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_INBOX_NAME=INBOX
EMAIL_POLL_INTERVAL_MINUTES=15
EMAIL_SEARCH_SENDERS=
EMAIL_GMAIL_CLIENT_ID=
EMAIL_GMAIL_CLIENT_SECRET=
EMAIL_GMAIL_REFRESH_TOKEN=

# ---------------------------------------------------------------------------
# STORAGE (File System)
# ---------------------------------------------------------------------------
STORAGE_BASE_PATH=storage
STORAGE_RESUMES_PATH=storage/resumes
STORAGE_JOBS_PATH=storage/jobs
STORAGE_LOGS_PATH=storage/logs
STORAGE_TEMPLATES_PATH=templates
STORAGE_MAX_FILE_SIZE_MB=10
STORAGE_ALLOWED_RESUME_FORMATS=.pdf,.docx,.md,.txt

# ---------------------------------------------------------------------------
# JOB COLLECTION (Scraping & Discovery)
# ---------------------------------------------------------------------------
JOB_COLLECTION_MAX_DAILY=50
JOB_COLLECTION_DELAY_BETWEEN_REQUESTS_MS=3000
JOB_COLLECTION_MAX_RETRIES=3
JOB_COLLECTION_RETRY_BACKOFF_FACTOR=2.0
JOB_COLLECTION_SOURCES_ENABLED=linkedin,indeed
JOB_COLLECTION_SEARCH_KEYWORDS=
JOB_COLLECTION_SEARCH_LOCATIONS=
JOB_COLLECTION_SEARCH_RADIUS_KM=50
JOB_COLLECTION_DEDUP_WINDOW_HOURS=72
JOB_COLLECTION_MAX_PAGES_PER_SOURCE=5
JOB_COLLECTION_RESPECT_ROBOTS_TXT=true
JOB_COLLECTION_PROXY_URL=

# ---------------------------------------------------------------------------
# APPLICATION (Submission & Tracking)
# ---------------------------------------------------------------------------
APPLICATION_MAX_DAILY=10
APPLICATION_REQUIRE_REVIEW=true
APPLICATION_AUTO_SUBMIT=false
APPLICATION_ALWAYS_ATTACH_COVER_LETTER=true
APPLICATION_DEFAULT_STATUS=discovered
APPLICATION_SCREENSHOT_ON_SUBMIT=true
APPLICATION_SCREENSHOT_ON_REVIEW=true
APPLICATION_FILL_PERSONAL_DETAILS=true
APPLICATION_FILL_WORK_HISTORY=true
APPLICATION_FILL_EDUCATION=true
APPLICATION_PAUSE_ON_UNKNOWN_FIELD=true
APPLICATION_MAX_FORM_FILL_ATTEMPTS=3
